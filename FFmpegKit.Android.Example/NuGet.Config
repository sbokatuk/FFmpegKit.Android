<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!-- Local feed: the .nupkg produced by FFmpegKit.Android/BuildNugets.sh lands directly
         in this folder. Kept in sync with FFmpegKitVersion by UpdateExampleReference.sh. -->
    <add key="LocalFFmpegKit" value="../FFmpegKit.Android" />
  </packageSources>
</configuration>
