<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <!--
      Locally packed FFmpegKit packages. The device tests reference the packed .nupkg rather than
      the binding project, so the e2e runs against exactly what gets published.
    -->
    <add key="local-artifacts" value="artifacts" />
  </packageSources>
</configuration>
